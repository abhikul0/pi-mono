(version 1)
(deny default)
(allow process*)
(allow file*)
(deny file-write*)
(allow process-exec)
(allow file-read*)
(allow file-read-data)
(deny file-read* (literal "/Users/abhishek/.ssh"))
(allow mach-lookup)
(allow sysctl-read)
(allow ipc*)
(allow network*)
(allow file-write* (subpath "/Users/abhishek/.pi/"))
(allow file-write* (subpath "/Users/abhishek/pi/workspace/"))